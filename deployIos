#!/bin/bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
XCODE_PROJECT="${XCODE_PROJECT:-$PROJECT_DIR/iosApp/iosApp.xcodeproj}"
SCHEME="${SCHEME:-iosApp}"
CONFIGURATION="${CONFIGURATION:-Debug}"
DERIVED_DATA="${DERIVED_DATA:-/tmp/OpenAceDerivedData}"
SDK="${SDK:-iphoneos}"
INSTALL="${INSTALL:-1}"
TEAM_ID="${DEVELOPMENT_TEAM:-}"
DEVICE_ID="${IOS_DEPLOY_DEVICE_ID:-}"
ARCHIVE_PATH="${ARCHIVE_PATH:-}"
EXPORT_DIR="${EXPORT_DIR:-$DERIVED_DATA/export}"

usage() {
  cat <<'EOF'
Usage: ./deployIos [options]

Builds/signs the iOS app and optionally installs it on a connected iPhone.

Options:
  --configuration Debug|Release   Build configuration (default: Debug)
  --derived-data PATH             DerivedData location (default: /tmp/OpenAceDerivedData)
  --project PATH                  Xcode project path (default: ./iosApp/iosApp.xcodeproj)
  --scheme NAME                   Xcode scheme (default: iosApp)
  --device UDID                   Install to a specific device with ios-deploy
  --archive PATH                  Sign/export from a prebuilt .xcarchive
  --export-dir PATH               Export output directory when using --archive
  --no-install                    Build only, do not install to a device
  --team-id TEAM_ID               Override DEVELOPMENT_TEAM for signing
  -h, --help                      Show this help text

Environment variables:
  CONFIGURATION, DERIVED_DATA, XCODE_PROJECT, SCHEME, IOS_DEPLOY_DEVICE_ID,
  DEVELOPMENT_TEAM, INSTALL, ARCHIVE_PATH, EXPORT_DIR
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --configuration)
      CONFIGURATION="$2"
      shift 2
      ;;
    --derived-data)
      DERIVED_DATA="$2"
      shift 2
      ;;
    --project)
      XCODE_PROJECT="$2"
      shift 2
      ;;
    --scheme)
      SCHEME="$2"
      shift 2
      ;;
    --device)
      DEVICE_ID="$2"
      shift 2
      ;;
    --archive)
      ARCHIVE_PATH="$2"
      shift 2
      ;;
    --export-dir)
      EXPORT_DIR="$2"
      shift 2
      ;;
    --no-install)
      INSTALL=0
      shift
      ;;
    --team-id)
      TEAM_ID="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

mkdir -p "$DERIVED_DATA"

if [[ -z "$TEAM_ID" ]]; then
  for candidate in \
    "$PROJECT_DIR/iosApp/Configuration/Config.local.xcconfig" \
    "$PROJECT_DIR/iosApp/Configuration/Config.xcconfig"
  do
    if [[ -f "$candidate" ]]; then
      TEAM_ID="$(rg -m1 -o '^TEAM_ID[[:space:]]*=[[:space:]]*[A-Z0-9]+' "$candidate" 2>/dev/null | sed 's/.*= *//' || true)"
      if [[ -n "$TEAM_ID" && "$TEAM_ID" != "YOUR_TEAM_ID_HERE" ]]; then
        break
      fi
      TEAM_ID=""
    fi
  done
fi

if [[ -z "$TEAM_ID" ]]; then
  echo "Unable to determine DEVELOPMENT_TEAM." >&2
  echo "Copy iosApp/Configuration/Config.local.xcconfig.example to Config.local.xcconfig and set TEAM_ID, or pass DEVELOPMENT_TEAM=YOUR_TEAM_ID." >&2
  exit 2
fi

echo "Using Apple Team ID: $TEAM_ID"

APP_PATH=""
cleanup_dir=""

if [[ -n "$ARCHIVE_PATH" ]]; then
  if [[ ! -d "$ARCHIVE_PATH" ]]; then
    echo "Archive not found: $ARCHIVE_PATH" >&2
    exit 1
  fi

  mkdir -p "$EXPORT_DIR"
  export_plist="$(mktemp)"
  cat >"$export_plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>method</key>
  <string>development</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>teamID</key>
  <string>$TEAM_ID</string>
</dict>
</plist>
EOF

  echo "Signing/exporting from archive: $ARCHIVE_PATH"
  xcodebuild \
    -exportArchive \
    -archivePath "$ARCHIVE_PATH" \
    -exportPath "$EXPORT_DIR" \
    -exportOptionsPlist "$export_plist" \
    -allowProvisioningUpdates

  rm -f "$export_plist"

  IPA_PATH="$(find "$EXPORT_DIR" -maxdepth 1 -name '*.ipa' -print -quit 2>/dev/null || true)"
  if [[ -z "$IPA_PATH" ]]; then
    echo "Export succeeded, but no .ipa found under $EXPORT_DIR" >&2
    exit 1
  fi

  cleanup_dir="$(mktemp -d)"
  unzip -q "$IPA_PATH" -d "$cleanup_dir"
  APP_PATH="$(find "$cleanup_dir/Payload" -maxdepth 1 -name '*.app' -print -quit 2>/dev/null || true)"

  if [[ -z "$APP_PATH" ]]; then
    echo "No .app found in exported IPA: $IPA_PATH" >&2
    rm -rf "$cleanup_dir"
    exit 1
  fi

  echo "Exported and signed IPA: $IPA_PATH"
else
  build_args=(
    -project "$XCODE_PROJECT"
    -scheme "$SCHEME"
    -configuration "$CONFIGURATION"
    -sdk "$SDK"
    -destination "generic/platform=iOS"
    -derivedDataPath "$DERIVED_DATA"
    -allowProvisioningUpdates
  )

  if [[ -n "$TEAM_ID" ]]; then
    build_args+=(DEVELOPMENT_TEAM="$TEAM_ID")
  fi

  build_args+=(build)

  echo "Building $SCHEME ($CONFIGURATION) for iPhone..."
  xcodebuild "${build_args[@]}"

  APP_DIR="$DERIVED_DATA/Build/Products/${CONFIGURATION}-iphoneos"
  APP_PATH="$(find "$APP_DIR" -maxdepth 1 -name '*.app' -print -quit 2>/dev/null || true)"

  if [[ -z "$APP_PATH" ]]; then
    echo "Build succeeded, but no .app was found under $APP_DIR" >&2
    exit 1
  fi

  echo "Built app: $APP_PATH"
fi

if [[ "$INSTALL" != "1" ]]; then
  if [[ -n "$cleanup_dir" ]]; then
    rm -rf "$cleanup_dir"
  fi
  exit 0
fi

if ! command -v ios-deploy >/dev/null 2>&1; then
  cat <<EOF
ios-deploy is not installed.
Install it with:
  brew install ios-deploy

Then run:
  ios-deploy --bundle "$APP_PATH"
EOF
  exit 0
fi

deploy_args=(--bundle "$APP_PATH")
if [[ -n "$DEVICE_ID" ]]; then
  deploy_args+=(--id "$DEVICE_ID")
fi

echo "Installing to device with ios-deploy..."
set +e
deploy_output="$(ios-deploy "${deploy_args[@]}" 2>&1)"
deploy_status=$?
set -e
printf '%s\n' "$deploy_output"

if [[ $deploy_status -ne 0 ]]; then
  if printf '%s' "$deploy_output" | rg -q "does not recognize this host"; then
    cat <<'EOF' >&2
The iPhone has not trusted this Mac yet.
Unlock the iPhone and accept the trust prompt, or disconnect/reconnect the cable while the phone is unlocked.
EOF
  fi
  if [[ -n "$cleanup_dir" ]]; then
    rm -rf "$cleanup_dir"
  fi
  exit $deploy_status
fi

if [[ -n "$cleanup_dir" ]]; then
  rm -rf "$cleanup_dir"
fi
